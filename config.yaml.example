# =============================================================================
#  VFS Global appointment bot — configuration
#  Copy this file to  config.yaml  and fill in your values.
#  config.yaml is git-ignored (it has secrets).
# =============================================================================

# --- Which VFS portal -------------------------------------------------------
# This is the path segment of the login URL:
#   https://visa.vfsglobal.com/<this>/login
# For "Russia -> France" it is "rus/en/fra".
# Change it if you apply from another country.
portal:
  url_segment: "rus/en/fra"
  # Full login URL is derived as https://visa.vfsglobal.com/<url_segment>/login
  # Override here only if VFS changes the scheme:
  login_url: ""          # leave empty to auto-build

# --- VFS account credentials ------------------------------------------------
account:
  # If account_pool.enabled=true and account_pool.vfs_password is set, these
  # fixed credentials are only fallback values.
  email: "you@example.com"
  password: "your-vfs-password"

# --- OTP handling -----------------------------------------------------------
# VFS sends a one-time code by email at login and (sometimes) before
# confirming the booking.
#   mode: "manual" -> the bot prints ">>> ENTER OTP:" and waits for you to
#                     type it in the terminal.
#   mode: "imap"       -> the bot reads the code automatically from a mailbox.
#   mode: "notletters" -> the bot reads the code through NotLetters API.
otp:
  mode: "manual"          # "manual" | "imap" | "notletters"
  imap:
    host: "imap.gmail.com"
    port: 993
    user: "you@gmail.com"
    # For Gmail use an App Password, not your main password.
    password: "app-password-here"
    # Folder to search and the sender / subject to match.
    folder: "INBOX"
    from_contains: "vfsglobal"
    # How long to keep polling the mailbox for a fresh code (seconds).
    wait_seconds: 120
  notletters:
    api_key: "env:NOTLETTERS_API_KEY"
    base_url: "https://api.notletters.com"
    # email/password are filled automatically from account_pool when enabled.
    email: ""
    password: ""
    search: "VFS"
    from_contains: "vfsglobal"
    wait_seconds: 120
    poll_seconds: 5

# --- Optional VFS account pool ----------------------------------------------
# Reads mailbox credentials from `accounts_file` (`email:mailbox_password` per
# line), uses `vfs_password` as the VFS login password, stores separate session
# cookies per account, and rotates accounts on login restrictions/timeouts.
account_pool:
  enabled: false
  accounts_file: "needed/emails.txt"
  state_file: "saved_cookies/account_pool_state.json"
  vfs_password: ""          # leave empty to use account.password for every pooled account
  per_account_cookies: true
  max_failures_per_account: 1
  cooldown_minutes: 60
  restricted_cooldown_minutes: 1440

# --- Optional VFS account auto-registration --------------------------------
# Uses account_pool mailboxes, fills the VFS registration form, reads OTP /
# activation email through NotLetters, and marks accounts as registered in the
# pool state. Use a VFS password that matches the portal password policy.
registration:
  enabled: false
  auto_register: false       # true = register fresh pool accounts before login
  max_per_run: 1             # safety limit for automatic registration on normal runs
  activate_via_email: true
  activation_email_search: "VFS"
  activation_link_contains: "activateemail"
  activation_wait_seconds: 120
  # Optional defaults for portals that ask for personal data during account
  # registration. Empty values fall back to the first applicants[] record.
  defaults:
    first_name: ""
    last_name: ""
    date_of_birth: ""
    passport_number: ""
    nationality: ""
  random_phone:
    country_code: "+7"
    digits: 10
    prefixes: ["900", "901", "902", "903", "904", "905", "906", "909"]

# --- What appointment you want ---------------------------------------------
# These strings must match EXACTLY what appears in the dropdowns on the site
# (visa application centre, category, sub-category). Run with --inspect first
# to have the bot print the available options, then paste them here.
appointment:
  visa_centre: "France Visa Application Centre - Moscow"
  visa_category: "Short term visa (up to 90 days)"
  visa_sub_category: "Tourism"
  # Optional: only accept slots inside this date window (YYYY-MM-DD).
  # Leave empty to accept any available date.
  earliest_date: ""
  latest_date: ""
  any_date: false               # true = ignore earliest_date/latest_date
  excluded_dates: []            # e.g. ["2026-06-01", "2026-06-02"]
  date_preference: "earliest"   # "earliest", "latest", "random", or empty
  # Number of applicants in this booking (usually 1).
  applicants_count: 1

# --- Applicant personal data (used only for auto-booking) -------------------
# Needed only if auto_book is true. Some portals pre-fill these from the
# account; in that case the bot just clicks through.
applicants:
  - first_name: "IVAN"
    last_name: "IVANOV"
    passport_number: "00AB123456"
    passport_expiry: "2030-01-01"      # YYYY-MM-DD
    date_of_birth: "1990-01-01"        # YYYY-MM-DD
    nationality: "Russian"
    gender: "Male"                     # Male / Female
    phone_country_code: "+7"
    phone_number: "9990000000"
    email: "you@example.com"

# --- Behaviour --------------------------------------------------------------
behaviour:
  # false = only monitor + notify; true = also try to book the slot.
  auto_book: true
  # true = walk the booking flow but stop before clicking final Confirm/Pay.
  auto_book_dry_run: false
  # Seconds to wait between availability checks. DO NOT make this tiny —
  # VFS bans accounts for hammering. 600-1200s (10-20 min) is sane; with a
  # bit of jitter applied automatically.
  check_interval_seconds: 900
  # Random extra delay added to every wait, in seconds [min, max].
  jitter_seconds: [30, 180]
  # Stop after this many successful bookings (then exit). 0 = never stop.
  stop_after_bookings: 1
  # Re-login if the session looks dead this many checks in a row failed.
  relogin_after_failures: 3

# --- Network ----------------------------------------------------------------
network:
  # STRONGLY RECOMMENDED. VFS/Cloudflare blocks datacenter/hosting IPs at the
  # edge (HTTP 403 with code 403201). Use a RESIDENTIAL or MOBILE proxy whose
  # exit IP is in the country you apply from.
  # Format: "user:pass@host:port"  or  "host:port"  (leave empty for none).
  proxy: ""                 # or "env:VFS_PROXY"; default env fallback is VFS_PROXY
  # Run the browser without a visible window. Set false the first few runs so
  # you can watch diagnostics; captcha solving still stays automated.
  headless: false
  # Pin a specific Chrome major version if SeleniumBase picks a wrong one.
  chrome_version: ""        # e.g. "126" — leave empty for auto
  # Optional fixed Chrome profile dir. Usually leave empty; the bot creates a
  # per-process profile under .tmp to avoid broken system temp permissions.
  user_data_dir: ""
  # Optional: attach to an already-open Chrome DevTools endpoint. Usually leave
  # empty; can also be set via VFS_DEBUGGER_ADDRESS for recovery/debug sessions.
  debugger_address: ""
  # Optional: expose the SeleniumBase Chrome on a DevTools port for live
  # inspection/debugging. Can also be set via VFS_REMOTE_DEBUG_PORT.
  remote_debug_port: ""
  # Fail fast if the configured proxy cannot reach a simple IP-check endpoint.
  proxy_precheck: true
  # Authenticated proxies can fail in Chrome with HTTP 407. Keep this enabled
  # so the browser uses a local no-auth bridge while the bot authenticates to
  # the upstream proxy itself.
  proxy_auth_bridge: true
  proxy_check_url: "https://api.ipify.org?format=json"
  proxy_check_timeout_seconds: 20
  # Prevent Selenium from hanging forever when VFS returns a half-loaded page.
  page_load_timeout_seconds: 35

# --- Session reuse ----------------------------------------------------------
# Optional: reuse a manually logged-in browser state instead of passing the
# VFS login Turnstile every run. The file contains auth cookies/tokens and is
# sensitive; keep it local. The default folder is git-ignored.
session:
  cookies_file: ""          # e.g. "saved_cookies/vfs_svn.json" or "env:VFS_SESSION_COOKIES"
  import_cookies: true      # try this file before normal login
  export_cookies: true      # refresh this file after a successful login/session
  manual_login: false       # false = auto-enter account.email/password; true = wait for manual login
  manual_login_wait_seconds: 300

# --- Captcha solver (Cloudflare Turnstile) ----------------------------------
# The bot never uses GUI captcha click helpers because they move the real
# Windows mouse. Configure a paid solver here for Turnstile.
#
# Supported providers:
#   "none"      - disabled (fail if Turnstile does not clear automatically).
#   "capsolver" — https://capsolver.com (recommended; ~$0.8 / 1000 Turnstile).
#   "twocaptcha"— https://2captcha.com  (TODO: not implemented yet).
captcha:
  provider: "none"          # "none" | "capsolver"
  api_key: ""               # CapSolver key, "env:CAPSOLVER_API_KEY", or leave empty to read CAPSOLVER_API_KEY
  timeout_seconds: 120      # max time to wait for a token
  cloudflare_retries: 2     # API challenge retries; second attempt sends fresh 403 HTML to CapSolver
  proxy: ""                 # optional; must match the browser proxy when solving Cloudflare API challenges

# --- Telegram notifications (optional) --------------------------------------
# Create a bot via @BotFather, get its token; get your chat id from @userinfobot.
# Leave bot_token empty to disable Telegram and just log to console.
telegram:
  bot_token: ""
  chat_id: ""
  # Also send a heartbeat every N checks so you know it's alive (0 = off).
  heartbeat_every: 12

# --- Logging ----------------------------------------------------------------
logging:
  level: "INFO"             # DEBUG / INFO / WARNING / ERROR
  # Save a screenshot on every error / important step.
  screenshots: true
  screenshot_dir: "screenshots"
